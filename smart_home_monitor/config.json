{
  "name": "Home Assistant Monitor",
  "version": "1.1.7",
  "slug": "smart_home_monitor",
  "description": "Мониторинг Zigbee устройств, заряда батарей и уведомлений. Источник данных: Zigbee2MQTT + Home Assistant API.",
  "url": "https://github.com/Onizyka/ha-monitor",
  "arch": [
    "aarch64",
    "amd64",
    "armv7"
  ],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "ingress": true,
  "ingress_port": 8080,
  "ingress_stream": true,
  "panel_icon": "mdi:home-automation",
  "panel_title": "Smart Monitor",
  "hassio_api": true,
  "homeassistant_api": true,
  "auth_api": true,
  "options": {
    "mqtt_host": "core-mosquitto",
    "mqtt_port": 1883,
    "mqtt_user": "mqtt",
    "mqtt_password": "mqtt",
    "mqtt_topic_prefix": "zigbee2mqtt",
    "db_host": "core-mariadb",
    "db_port": 3306,
    "db_name": "smarthome",
    "db_user": "smarthome",
    "db_password": "pass",
    "ha_url": "http://supervisor/core",
    "ha_token": "",
    "telegram_enabled": false,
    "telegram_token": "",
    "telegram_chat_id": "",
    "max_enabled": false,
    "max_token": "",
    "max_chat_id": "",
    "pump_entity_ids": [],
    "log_level": "info"
  },
  "schema": {
    "mqtt_host": "str",
    "mqtt_port": "int(1,65535)",
    "mqtt_user": "str?",
    "mqtt_password": "password?",
    "mqtt_topic_prefix": "str",
    "db_host": "str",
    "db_port": "int(1,65535)",
    "db_name": "str",
    "db_user": "str",
    "db_password": "password",
    "ha_url": "url",
    "ha_token": "str?",
    "telegram_enabled": "bool",
    "telegram_token": "str?",
    "telegram_chat_id": "str?",
    "max_enabled": "bool",
    "max_token": "str?",
    "max_chat_id": "str?",
    "pump_entity_ids": [
      "str?"
    ],
    "log_level": "list(debug|info|warning|error)"
  }
}